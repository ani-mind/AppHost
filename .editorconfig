# Идентификатор корня. Говорит анализатору прекратить поиск других файлов .editorconfig выше по древу папок.
root = true

# Настройки для абсолютно всех файлов в проекте
[*]
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Настройки для YAML/YML (GitHub Actions, Docker Compose и т.д.)
[*.{yml,yaml}]
indent_size = 2

# Настройки специфичные для C# кода
[*.cs]

# Настройки форматирования (Formatting Rules)
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true

# Стили кодирования (Code Style Rules)
# Предпочитать var для встроенных типов, если тип очевиден
csharp_style_var_for_built_in_types = true:suggestion
# Предпочитать явный тип, когда инициализация неочевидна
csharp_style_var_elsewhere = true:suggestion

# Требовать модификаторы доступности явно
dotnet_style_require_accessibility_modifiers = always:warning

# Запрещаем IDE удалять скобки и требуем их наличия всегда
csharp_prefer_braces = true:warning

# Правила именования (Naming Conventions)
# 1. Интерфейсы должны начинаться с буквы I
dotnet_naming_rule.interface_should_be_begun_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface_symbols
dotnet_naming_rule.interface_should_be_begun_with_i.style = name_should_begun_with_i

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface

dotnet_naming_style.name_should_begun_with_i.required_prefix = I
dotnet_naming_style.name_should_begun_with_i.capitalization = pascal_case

# 2. Приватные поля: _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.style = camel_case_with_underscore_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.camel_case_with_underscore_style.required_prefix = _
dotnet_naming_style.camel_case_with_underscore_style.capitalization = camel_case

# 3. Свойства и методы: PascalCase
dotnet_naming_rule.properties_and_methods_should_be_pascal_case.severity = warning
dotnet_naming_rule.properties_and_methods_should_be_pascal_case.symbols = properties_and_methods
dotnet_naming_rule.properties_and_methods_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.properties_and_methods.applicable_kinds = property, method
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# 4. Константы: PascalCase
dotnet_naming_rule.constants_should_be_pascal_case.severity = warning
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constants
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

# 5. Локальные переменные и параметры: camelCase
dotnet_naming_rule.locals_and_parameters_should_be_camel_case.severity = warning
dotnet_naming_rule.locals_and_parameters_should_be_camel_case.symbols = locals_and_parameters
dotnet_naming_rule.locals_and_parameters_should_be_camel_case.style = camel_case_style

dotnet_naming_symbols.locals_and_parameters.applicable_kinds = parameter, local
dotnet_naming_style.camel_case_style.capitalization = camel_case

#### Настройки StyleCop (SA) ####

# SA1633: Отключаем обязательный копирайт-заголовок в начале каждого файла
dotnet_diagnostic.SA1633.severity = none

# SA1200: Разрешаем писать using вне namespace (стандарт для современного C#)
dotnet_diagnostic.SA1200.severity = none

# SA1600: Глобально глушим требования к комментариям (дополнение к stylecop.json)
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none

# КРИТИЧНО ДЛЯ НЕЙМИНГА:
# SA1309: StyleCop ненавидит подчеркивания в приватных полях (_myField). 
# Так как мы ранее договорились использовать _camelCase, мы обязаны убить это правило.
dotnet_diagnostic.SA1309.severity = none

# SA1101: Отключаем обязательное требование писать 'this.' перед вызовом свойств и методов внутри класса
dotnet_diagnostic.SA1101.severity = none

# SA1516: Отключаем требование пустой строки между using и namespace (неактуально с file-scoped namespaces)
dotnet_diagnostic.SA1516.severity = none

# SA1413: Разрешаем IDE удалять висячие запятые
dotnet_diagnostic.SA1413.severity = none

# SA0001: Запрещаем StyleCop паниковать из-за выключенной генерации XML-доков компилятором
dotnet_diagnostic.SA0001.severity = none